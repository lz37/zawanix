{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "auto_update": true,
  "tmux": {
    "isolation": "inline",
    "enabled": true,
    "layout": "main-horizontal",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "sisyphus_agent": {
    "disabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "start_work": {
    "auto_commit": true
  },
  "background_task": {
    "staleTimeoutMs": 1800000,
    "modelConcurrency": {
      "github-copilot/claude-opus-4.6": 2,
      "github-copilot/gpt-5.4": 4,
      "github-copilot/claude-haiku-4.5": 20,
      "github-copilot/grok-code-fast-1": 20,
      "github-copilot/gpt-5.4-mini": 20,
      "github-copilot/gemini-3-flash-preview": 20
    }
  },
  "disabled_mcps": ["websearch", "grep_app", "context7"],
  "agents": {
    "sisyphus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "opencode-go/mimo-v2-pro",
      "variant": "medium"
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7"
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.5"
    },
    "prometheus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high"
    },
    "metis": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "thinking"
    },
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/glm-5"
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview"
    },
    "quick": {
      "model": "github-copilot/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "opencode-go/kimi-k2.5"
    },
    "unspecified-high": {
      "model": "opencode-go/glm-5"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview"
    }
  }
}
