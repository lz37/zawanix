{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "auto_update": true,
  // "tmux": {
  //   "isolation": "inline",
  //   "enabled": true,
  //   "layout": "main-horizontal",
  //   "main_pane_size": 60,
  //   "main_pane_min_width": 120,
  //   "agent_pane_min_width": 40
  // },
  "sisyphus_agent": {
    "disabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "start_work": {
    "auto_commit": true
  },
  "background_task": {
    "staleTimeoutMs": 1800000,
    "modelConcurrency": {
      "github-copilot/claude-opus-4.7": 1,
      "github-copilot/gpt-5.4": 2,
      "kimi-for-coding-oauth/kimi-for-coding": 2
    }
  },
  "disabled_mcps": ["websearch", "grep_app", "context7"],
  "agents": {
    "sisyphus": {
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled"
      }
    },
    "plan": {
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled"
      }
    },
    "sisyphus-junior": {
      "model": "zenmux/moonshotai/kimi-k2.5"
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "explore": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "multimodal-looker": {
      "model": "zenmux/moonshotai/kimi-k2.5"
    },
    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled"
      }
    },
    "metis": {
      "model": "zenmux/anthropic/claude-opus-4.7",
      "variant": "max"
    },
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled"
      }
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "zenmux/google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium"
    },
    "artistry": {
      "model": "zenmux/google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "quick": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "unspecified-low": {
      "model": "zenmux/moonshotai/kimi-k2.5"
    },
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-pro",
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled"
      }
    },
    "writing": {
      "model": "deepseek/deepseek-v4-flash"
    }
  }
}
