{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "@simonwjackson/opencode-direnv@latest",
    "opencode-wakatime@latest",
    "opencode-pty@latest",
    "cc-safety-net@latest",
    "@mailshieldai/opencode-canvas@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "autoupdate": "notify",
  "permission": {
    "canvas_*": "allow"
  },
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "https://zenmux.ai/api/anthropic/v1",
        "setCacheKey": true
      }
    }
  },
  "agent": {
    "compaction": {
      "model": "zenmux/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "summary": {
      "model": "zenmux/deepseek/deepseek-v4-flash",
      "variant": "max"
    },
    "title": {
      "model": "zenmux/deepseek/deepseek-v4-flash",
      "variant": "high"
    }
  }
}
